<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="view.RegistrationTableView">
  <grid id="27dc6" binding="pnlMain" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="808" height="447"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="a4c9f" binding="pnlTop" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="2">
        <constraints border-constraint="North"/>
        <properties/>
        <border type="line"/>
        <children>
          <component id="9cfdd" class="javax.swing.JComboBox" binding="cmbFilter">
            <constraints/>
            <properties>
              <model>
                <item value="ID"/>
                <item value="NOME"/>
                <item value="DOCUMENTO"/>
              </model>
              <preferredSize width="135" height="30"/>
            </properties>
          </component>
          <component id="411dd" class="javax.swing.JTextField" binding="txtSearch">
            <constraints/>
            <properties>
              <preferredSize width="200" height="24"/>
              <requestFocusEnabled value="false"/>
            </properties>
          </component>
          <component id="d9946" class="javax.swing.JButton" binding="btnSearch">
            <constraints/>
            <properties>
              <preferredSize width="150" height="23"/>
              <text value="Pesquisar"/>
            </properties>
          </component>
        </children>
      </grid>
      <scrollpane id="7fe1e" binding="scpCenter">
        <constraints border-constraint="Center"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="6195e" class="javax.swing.JTable" binding="tbeItens">
            <constraints/>
            <properties/>
          </component>
        </children>
      </scrollpane>
      <grid id="b0f62" binding="pnlLow" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="2">
        <constraints border-constraint="South"/>
        <properties/>
        <border type="line"/>
        <children>
          <component id="bf868" class="javax.swing.JButton" binding="btnDelete">
            <constraints/>
            <properties>
              <text value="Deletar"/>
            </properties>
          </component>
          <component id="e4dea" class="javax.swing.JButton" binding="btnEdit">
            <constraints/>
            <properties>
              <text value="Editar"/>
            </properties>
          </component>
          <component id="5421" class="javax.swing.JButton" binding="btnAdd">
            <constraints/>
            <properties>
              <text value="Adicionar"/>
            </properties>
          </component>
        </children>
      </grid>
    </children>
  </grid>
</form>
