<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="view.ProductionTableView">
  <grid id="27dc6" binding="pnlMain" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="670" height="435"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="6e1e9" binding="pnlTop" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="2">
        <constraints border-constraint="North"/>
        <properties/>
        <border type="line"/>
        <children>
          <component id="9c902" class="javax.swing.JComboBox" binding="cmbFilter">
            <constraints/>
            <properties>
              <model>
                <item value="ID"/>
                <item value="REGISTRO"/>
              </model>
              <preferredSize width="135" height="30"/>
            </properties>
          </component>
          <component id="f98be" class="javax.swing.JTextField" binding="txtSearch">
            <constraints/>
            <properties>
              <preferredSize width="200" height="24"/>
            </properties>
          </component>
          <component id="e881a" class="javax.swing.JButton" binding="btnSearch">
            <constraints/>
            <properties>
              <preferredSize width="150" height="23"/>
              <text value="Pesquisar"/>
            </properties>
          </component>
        </children>
      </grid>
      <scrollpane id="5f11e" binding="scpCenter">
        <constraints border-constraint="Center"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="5deb1" class="javax.swing.JTable" binding="tbeItens">
            <constraints/>
            <properties/>
          </component>
        </children>
      </scrollpane>
      <grid id="b221c" binding="pnlLow" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="2">
        <constraints border-constraint="South"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="7ac47" class="javax.swing.JButton" binding="btnDelete">
            <constraints/>
            <properties>
              <preferredSize width="89" height="30"/>
              <text value="Deletar"/>
            </properties>
          </component>
          <component id="6e2af" class="javax.swing.JButton" binding="btnEdit">
            <constraints/>
            <properties>
              <text value="Editar"/>
            </properties>
          </component>
          <component id="a2b04" class="javax.swing.JButton" binding="btnAdd">
            <constraints/>
            <properties>
              <text value="Adicionar"/>
            </properties>
          </component>
        </children>
      </grid>
    </children>
  </grid>
</form>
