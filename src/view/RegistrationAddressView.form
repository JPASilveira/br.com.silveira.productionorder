<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="view.RegistrationAddressView">
  <grid id="27dc6" binding="pnlRegistrationAddress" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="158b" binding="pnlTitle" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="1">
        <constraints border-constraint="North"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="e1c0" class="javax.swing.JLabel" binding="lblId">
            <constraints/>
            <properties>
              <text value="ID:"/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="2b4aa" binding="pnlBaseboard" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="2">
        <constraints border-constraint="South"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="c935" class="javax.swing.JButton" binding="bntSave">
            <constraints/>
            <properties>
              <text value="Salvar"/>
            </properties>
          </component>
          <component id="5c7bb" class="javax.swing.JButton" binding="bntReturn">
            <constraints/>
            <properties>
              <text value="Retornar"/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="89b97" binding="pnlContent" layout-manager="GridLayoutManager" row-count="1" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints border-constraint="Center"/>
        <properties/>
        <border type="none"/>
        <children>
          <grid id="4c51e" binding="pnlLeft" layout-manager="GridLayoutManager" row-count="6" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
            <margin top="0" left="0" bottom="0" right="0"/>
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children>
              <grid id="ef2fb" binding="pnlLeftOne" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="0">
                <constraints>
                  <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties/>
                <border type="none"/>
                <children>
                  <component id="179cd" class="javax.swing.JLabel" binding="lblStreet">
                    <constraints/>
                    <properties>
                      <text value="Rua:    "/>
                    </properties>
                  </component>
                  <component id="64a7e" class="javax.swing.JTextField" binding="txtStreet">
                    <constraints/>
                    <properties>
                      <text value="                               "/>
                    </properties>
                  </component>
                </children>
              </grid>
              <vspacer id="26be2">
                <constraints>
                  <grid row="5" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
                </constraints>
              </vspacer>
              <grid id="cf096" binding="pnlLeftTwo" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="0">
                <constraints>
                  <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties/>
                <border type="none"/>
                <children>
                  <component id="8aeab" class="javax.swing.JLabel" binding="lblNeighborhood">
                    <constraints/>
                    <properties>
                      <text value="Bairro:"/>
                    </properties>
                  </component>
                  <component id="27dde" class="javax.swing.JTextField" binding="txtNeighborhood">
                    <constraints/>
                    <properties>
                      <text value="                               "/>
                    </properties>
                  </component>
                </children>
              </grid>
              <grid id="3d77d" binding="pnlLeftThree" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="0">
                <constraints>
                  <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties/>
                <border type="none"/>
                <children>
                  <component id="3fe2f" class="javax.swing.JLabel" binding="lblState">
                    <constraints/>
                    <properties>
                      <text value="Estado:"/>
                    </properties>
                  </component>
                  <component id="5c0ca" class="javax.swing.JComboBox" binding="cmbState">
                    <constraints/>
                    <properties>
                      <model>
                        <item value="AC"/>
                        <item value="AL"/>
                        <item value="AP"/>
                        <item value="AM"/>
                        <item value="BA"/>
                        <item value="CE"/>
                        <item value="DF"/>
                        <item value="ES"/>
                        <item value="GO"/>
                        <item value="MA"/>
                        <item value="MT"/>
                        <item value="MS"/>
                        <item value="MG"/>
                        <item value="PA"/>
                        <item value="PB"/>
                        <item value="PR"/>
                        <item value="PE"/>
                        <item value="PI"/>
                        <item value="RJ"/>
                        <item value="RN"/>
                        <item value="RS"/>
                        <item value="RO"/>
                        <item value="RR"/>
                        <item value="SC"/>
                        <item value="SP"/>
                        <item value="SE"/>
                        <item value="TO"/>
                      </model>
                      <toolTipText value="Teste           "/>
                    </properties>
                  </component>
                </children>
              </grid>
              <grid id="ea0d0" binding="pnlLeftFour" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="0">
                <constraints>
                  <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties/>
                <border type="none"/>
                <children/>
              </grid>
              <grid id="f3cb6" binding="pnlLeftFive" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="0">
                <constraints>
                  <grid row="4" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties/>
                <border type="none"/>
                <children/>
              </grid>
            </children>
          </grid>
          <grid id="a75cd" binding="pnlRight" layout-manager="GridLayoutManager" row-count="6" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
            <margin top="0" left="0" bottom="0" right="0"/>
            <constraints>
              <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <toolTipText value="                               "/>
