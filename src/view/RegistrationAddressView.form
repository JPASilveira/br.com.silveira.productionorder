              <grid id="b4d6c" binding="pnlRightTwo" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="0">
                <constraints>
                  <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties/>
                <border type="none"/>
                <children>
                  <component id="d5240" class="javax.swing.JLabel" binding="lblCity">
                    <constraints/>
                    <properties>
                      <text value="Cidade:  "/>
                    </properties>
                  </component>
                  <component id="fd1bb" class="javax.swing.JTextField" binding="txtCity">
                    <constraints/>
                    <properties>
                      <text value="                               "/>
                    </properties>
                  </component>
                </children>
              </grid>
              <grid id="fe4da" binding="pnlRightThree" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="0">
                <constraints>
                  <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties/>
                <border type="none"/>
                <children/>
              </grid>
              <grid id="459a3" binding="pnlRightFour" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="0">
                <constraints>
                  <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties/>
