<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="view.ProductGroupView">
  <grid id="27dc6" binding="pnlProductGroup" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="158b" binding="pnlTitle" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="0">
        <constraints border-constraint="North"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="3aa86" class="javax.swing.JLabel" binding="lblId">
            <constraints/>
            <properties>
              <horizontalTextPosition value="10"/>
              <text value="ID: "/>
              <verifyInputWhenFocusTarget value="false"/>
              <verticalAlignment value="1"/>
              <verticalTextPosition value="0"/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="2b4aa" binding="pnlBaseboard" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="2">
        <constraints border-constraint="South"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="a7d9" class="javax.swing.JButton" binding="btnSave">
            <constraints/>
            <properties>
              <text value="Salvar"/>
            </properties>
          </component>
          <component id="e67b2" class="javax.swing.JButton" binding="btnReturn">
            <constraints/>
            <properties>
              <text value="Retomar"/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="89b97" binding="pnlContent" layout-manager="GridLayoutManager" row-count="1" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints border-constraint="Center"/>
        <properties/>
        <border type="none"/>
        <children>
          <grid id="4c51e" binding="pnlLeft" layout-manager="GridLayoutManager" row-count="6" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
            <margin top="0" left="0" bottom="0" right="0"/>
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children>
              <grid id="ef2fb" binding="pnlLeftOne" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="0">
                <constraints>
                  <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties/>
                <border type="none"/>
                <children>
                  <component id="c875f" class="javax.swing.JLabel" binding="lblName">
                    <constraints/>
                    <properties>
                      <text value="Nome do grupo:"/>
                    </properties>
                  </component>
                  <component id="64729" class="javax.swing.JTextField" binding="txtName">
                    <constraints/>
                    <properties>
                      <text value="                               "/>
                    </properties>
                  </component>
                </children>
              </grid>
              <vspacer id="26be2">
                <constraints>
                  <grid row="5" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
                </constraints>
              </vspacer>
              <grid id="cf096" binding="pnlLeftTwo" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="0">
                <constraints>
                  <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties/>
                <border type="none"/>
                <children/>
              </grid>
              <grid id="3d77d" binding="pnlLeftThree" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="0">
                <constraints>
                  <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties/>
                <border type="none"/>
                <children/>
              </grid>
              <grid id="ea0d0" binding="pnlLeftFour" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="0">
                <constraints>
                  <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties/>
                <border type="none"/>
                <children/>
              </grid>
              <grid id="f3cb6" binding="pnlLeftFive" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="0">
                <constraints>
                  <grid row="4" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties/>
                <border type="none"/>
                <children/>
              </grid>
            </children>
          </grid>
          <grid id="a75cd" binding="pnlRight" layout-manager="GridLayoutManager" row-count="6" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
            <margin top="0" left="0" bottom="0" right="0"/>
            <constraints>
              <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children>
              <grid id="d981d" binding="pnlRightOne" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="0">
                <constraints>
                  <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties/>
                <border type="none"/>
                <children/>
              </grid>
              <vspacer id="e20e5">
                <constraints>
                  <grid row="5" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
                </constraints>
              </vspacer>
              <grid id="b4d6c" binding="pnlRightTwo" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="0">
                <constraints>
                  <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties/>
                <border type="none"/>
                <children/>
              </grid>
              <grid id="fe4da" binding="pnlRightThree" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="0">
                <constraints>
                  <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties/>
                <border type="none"/>
                <children/>
              </grid>
              <grid id="459a3" binding="pnlRightFour" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="0">
                <constraints>
                  <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties/>
                <border type="none"/>
                <children/>
              </grid>
              <grid id="fd486" binding="pnlRightFive" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="0">
                <constraints>
                  <grid row="4" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties/>
                <border type="none"/>
                <children/>
              </grid>
            </children>
          </grid>
        </children>
      </grid>
    </children>
  </grid>
</form>
